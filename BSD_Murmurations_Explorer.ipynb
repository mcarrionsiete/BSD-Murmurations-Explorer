    "## Part 1: Data Download from LMFDB\n",
    "\n",
    "The LMFDB public API provides q-expansion coefficients for any elliptic curve:\n",
    "\n",
    "    https://www.lmfdb.org/EllipticCurve/Q/download_qexp/[LABEL]/[N]\n",
    "\n",
    "The coefficient $a(p)$ for prime $p$ equals $p + 1 - N_p$,\n",
    "where $N_p$ is the number of points on the curve over $\\mathbb{F}_p$.\n",
    "\n",
    "We download **5000 coefficients** per curve — covering the first ~669 primes (up to $p \\approx 4999$)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 2: LMFDB DOWNLOAD FUNCTIONS\n",
    "# ============================================================\n",
    "\n",
    "def download_lmfdb(label, n=5000):\n",
    "    \"\"\"Download q-expansion coefficients from LMFDB public API.\"\"\"\n",
    "    url = f'https://www.lmfdb.org/EllipticCurve/Q/download_qexp/{label}/{n}'\n",
    "    try:\n",
    "        with urllib.request.urlopen(url, timeout=15) as resp:\n",
    "            text = resp.read().decode('utf-8').strip()\n",
    "        coefs = np.array([int(x) for x in text.split(',')])\n",
    "        ap = {int(p): int(coefs[p]) for p in primerange(2, min(n, len(coefs)))\n",
    "              if p < len(coefs)}\n",
    "        print(f'  ✅ {label}: {len(coefs)} coefficients, {len(ap)} primes')\n",
    "        return {'label': label, 'coefs': coefs, 'ap': ap}\n",
    "    except Exception as e:\n",
    "        print(f'  ❌ Error {label}: {e}')\n",
    "        return None\n",
    "\n",
    "\n",
    "def ap_normalized(data, p_max=PRIMES_OPT):\n",
    "    \"\"\"Compute a_p / sqrt(p) for all primes up to p_max.\"\"\"\n",
    "    primes = sorted([p for p in data['ap'] if p <= p_max])\n",
    "    values = np.array([data['ap'][p] / np.sqrt(p) for p in primes])\n",
    "    return np.array(primes), values\n",
    "\n",
    "\n",
    "print('✅ Download functions ready')"
   ]
  },
