    "## Part 2: Birch's Original Experiment (1960)\n",
    "\n",
    "Birch and Swinnerton-Dyer observed that the cumulative sum\n",
    "\n",
    "$$S(X) = \\sum_{p \\leq X} \\log\\!\\left(\\frac{N_p}{p}\\right)$$\n",
    "\n",
    "where $N_p = p + 1 - a_p$, **diverges** for curves of positive rank\n",
    "and **stabilizes** for rank 0.\n",
    "\n",
    "This was the first computational evidence for BSD — done in the 1960s\n",
    "with some of the world's first computers. We replicate it here in seconds\n",
    "using real LMFDB data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 4: BIRCH'S ORIGINAL EXPERIMENT\n",
    "# ============================================================\n",
    "\n",
    "def birch_signal(data, p_max=350):\n",
    "    \"\"\"Cumulative sum: sum log(N_p / p) where N_p = p + 1 - a_p.\"\"\"\n",
    "    primes = sorted([p for p in data['ap'] if p <= p_max])\n",
    "    cumsum, total = [], 0.0\n",
    "    for p in primes:\n",
    "        Np = p + 1 - data['ap'][p]\n",
    "        if Np > 0:\n",
    "            total += np.log(Np / p)\n",
    "        cumsum.append(total)\n",
    "    return np.array(primes), np.array(cumsum)\n",
    "\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "\n",
    "for data, color, label in [\n",
    "    (pool_r0[0], '#2196F3', f\"Rank 0 — {pool_r0[0]['label']}\"),\n",
    "    (pool_r1[0], '#FF9800', f\"Rank 1 — {pool_r1[0]['label']}\"),\n",
    "    (pool_r2[0], '#E91E63', f\"Rank 2 — {pool_r2[0]['label']}\")\n",
    "]:\n",
    "    ps, acc = birch_signal(data)\n",
    "    ax.plot(ps, acc, color=color, linewidth=2.5, label=label)\n",
    "\n",
    "ax.axhline(0, color='black', lw=0.8, ls='--', alpha=0.5)\n",
    "ax.set_xlabel('Prime $p$')\n",
    "ax.set_ylabel(r'$\\sum_{q \\leq p} \\log(N_q/q)$')\n",
    "ax.set_title(\"Birch & Swinnerton-Dyer's Original Experiment (1960)\\n\"\n",
    "             \"Replicated with real LMFDB data\")\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('fig1_birch_experiment.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('✅ Rank 0: stabilizes | Rank 1 & 2: diverge — as BSD predicts')"
   ]
