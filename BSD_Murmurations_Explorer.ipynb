   "source": [
    "# BSD Murmurations Explorer\n",
    "## Elliptic curve rank classification via murmurations\n",
    "\n",
    "**Author**: Amateur from Valencia, Spain — March 2026  \n",
    "**Tools**: Python · LMFDB public API · Perplexity Pro + Claude Sonnet  \n",
    "**Formal training**: None beyond secondary school  \n",
    "\n",
    "---\n",
    "\n",
    "This notebook replicates and extends research on the **Birch and Swinnerton-Dyer Conjecture**,\n",
    "one of the 7 Millennium Prize Problems ($1M prize each).\n",
    "\n",
    "### What we do:\n",
    "1. Replicate Birch's original 1960 computational experiment\n",
    "2. Replicate the Murmurations phenomenon (Pozdnyakov 2022)\n",
    "3. Build a rank classifier (rank 0, 1, 2) using murmuration profiles\n",
    "4. Validate with Leave-One-Out test: **31/31 correct**\n",
    "5. Find the optimal resolution: **~350 primes** (original result)\n",
    "\n",
    "### Honesty disclaimer:\n",
    "> This is **NOT** a proof of BSD. It is an honest amateur replication\n",
    "> of frontier research, built with curiosity and AI assistance."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 1: IMPORTS\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import urllib.request\n",
    "from sympy import primerange\n",
    "\n",
    "plt.rcParams.update({\n",
    "    'figure.facecolor': 'white',\n",
    "    'axes.facecolor': '#f8f8f8',\n",
    "    'axes.grid': True,\n",
    "    'grid.alpha': 0.3,\n",
    "    'font.size': 11,\n",
    "    'axes.titlesize': 13,\n",
    "    'axes.titleweight': 'bold',\n",
    "    'figure.dpi': 150\n",
    "})\n",
    "\n",
    "PRIMES_OPT = 350\n",
    "\n",
    "print('Libraries loaded OK')\n",
    "print(f'numpy {np.__version__}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Part 1: Data Download from LMFDB\n",
    "\n",
    "The LMFDB public API provides q-expansion coefficients for any elliptic curve:\n",
    "\n",
    "    https://www.lmfdb.org/EllipticCurve/Q/download_qexp/[LABEL]/[N]\n",
    "\n",
    "The coefficient $a(p)$ for prime $p$ equals $p + 1 - N_p$,\n",
    "where $N_p$ is the number of points on the curve over $\\mathbb{F}_p$.\n",
    "\n",
    "We download **5000 coefficients** per curve."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 2: DOWNLOAD FUNCTIONS\n",
    "\n",
    "def download_lmfdb(label, n=5000):\n",
    "    url = f'https://www.lmfdb.org/EllipticCurve/Q/download_qexp/{label}/{n}'\n",
    "    try:\n",
    "        with urllib.request.urlopen(url, timeout=15) as resp:\n",
    "            text = resp.read().decode('utf-8').strip()\n",
    "        coefs = np.array([int(x) for x in text.split(',')])\n",
    "        ap = {int(p): int(coefs[p]) for p in primerange(2, min(n, len(coefs)))\n",
    "              if p < len(coefs)}\n",
    "        print(f'  OK {label}: {len(coefs)} coefficients, {len(ap)} primes')\n",
    "        return {'label': label, 'coefs': coefs, 'ap': ap}\n",
    "    except Exception as e:\n",
    "        print(f'  ERROR {label}: {e}')\n",
    "        return None\n",
    "\n",
    "\n",
    "def ap_normalized(data, p_max=PRIMES_OPT):\n",
    "    primes = sorted([p for p in data['ap'] if p <= p_max])\n",
    "    values = np.array([data['ap'][p] / np.sqrt(p) for p in primes])\n",
    "    return np.array(primes), values\n",
    "\n",
    "\n",
    "print('Functions ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 3: DOWNLOAD ALL POOLS\n",
    "\n",
    "print('Downloading RANK 0 pool (4 curves)...')\n",
    "labels_r0 = ['11.a1', '27.a1', '32.a1', '36.a1']\n",
    "pool_r0 = [d for d in [download_lmfdb(l) for l in labels_r0] if d]\n",
    "\n",
    "print('Downloading RANK 1 pool (15 curves)...')\n",
    "labels_r1 = [\n",
    "    '37.a1', '43.a1', '53.a1', '61.a1', '77.a1',\n",
    "    '79.a1', '83.a1', '89.a1', '91.a1', '92.a1',\n",
    "    '101.a1', '106.a1', '123.a1', '131.a1', '135.a1'\n",
    "]\n",
    "pool_r1 = [d for d in [download_lmfdb(l) for l in labels_r1] if d]\n",
    "\n",
    "print('Downloading RANK 2 pool (12 curves)...')\n",
    "labels_r2 = [\n",
    "    '389.a1', '433.a1', '446.a1', '563.a1', '571.b1', '655.a1',\n",
    "    '571.a1', '643.a1', '653.a1', '664.a1', '709.a1', '718.a1'\n",
    "]\n",
    "pool_r2 = [d for d in [download_lmfdb(l) for l in labels_r2] if d]\n",
    "\n",
    "print(f'Total: {len(pool_r0)+len(pool_r1)+len(pool_r2)} curves')\n",
    "print(f'Rank 0: {len(pool_r0)} | Rank 1: {len(pool_r1)} | Rank 2: {len(pool_r2)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Part 2: Birch's Original Experiment (1960)\n",
    "\n",
    "$$S(X) = \\sum_{p \\leq X} \\log\\left(\\frac{N_p}{p}\\right)$$\n",
    "\n",
    "**Diverges** for positive rank curves, **stabilizes** for rank 0.\n",
    "First computational evidence for BSD."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 4: BIRCH EXPERIMENT\n",
    "\n",
    "def birch_signal(data, p_max=350):\n",
    "    primes = sorted([p for p in data['ap'] if p <= p_max])\n",
    "    cumsum, total = [], 0.0\n",
    "    for p in primes:\n",
    "        Np = p + 1 - data['ap'][p]\n",
    "        if Np > 0:\n",
    "            total += np.log(Np / p)\n",
    "        cumsum.append(total)\n",
    "    return np.array(primes), np.array(cumsum)\n",
    "\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "\n",
    "for data, color, lbl in [\n",
    "    (pool_r0[0], '#2196F3', f\"Rank 0 - {pool_r0[0]['label']}\"),\n",
    "    (pool_r1[0], '#FF9800', f\"Rank 1 - {pool_r1[0]['label']}\"),\n",
    "    (pool_r2[0], '#E91E63', f\"Rank 2 - {pool_r2[0]['label']}\")\n",
    "]:\n",
    "    ps, acc = birch_signal(data)\n",
    "    ax.plot(ps, acc, color=color, linewidth=2.5, label=lbl)\n",
    "\n",
    "ax.axhline(0, color='black', lw=0.8, ls='--', alpha=0.5)\n",
    "ax.set_xlabel('Prime p')\n",
    "ax.set_ylabel('Cumulative sum log(Np/p)')\n",
    "ax.set_title('Birch and Swinnerton-Dyer Experiment (1960) - Replicated with LMFDB')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('fig1_birch.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Rank 0 stabilizes | Rank 1 and 2 diverge - as BSD predicts')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Part 3: Murmurations\n",
    "\n",
    "Discovered by Pozdnyakov (2022): averaging $a_p/\\sqrt{p}$ over many curves\n",
    "of the same rank reveals **coherent waves oscillating in opposite directions**\n",
    "depending on rank.\n",
    "\n",
    "Named after starling murmurations: individually chaotic, collectively structured.\n",
    "\n",
    "**Three visual properties:**\n",
    "- Points follow the Sato-Tate distribution (semicircle, bounded between -2 and 2)\n",
    "- They gravitate toward zero (Hasse theorem, 1930)\n",
    "- The average drifts in opposite directions per rank"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 5: MURMURATIONS\n",
    "\n",
    "def murmuration_profile(pool, p_max=PRIMES_OPT):\n",
    "    profiles = []\n",
    "    p_ref = None\n",
    "    for data in pool:\n",
    "        ps, vals = ap_normalized(data, p_max)\n",
    "        if p_ref is None:\n",
    "            p_ref = ps\n",
    "        vals_interp = np.interp(p_ref, ps, vals)\n",
    "        profiles.append(vals_interp)\n",
    "    matrix = np.array(profiles)\n",
    "    return p_ref, np.mean(matrix, axis=0), np.std(matrix, axis=0)\n",
    "\n",
    "\n",
    "p_r0, avg_r0, std_r0 = murmuration_profile(pool_r0)\n",
    "p_r1, avg_r1, std_r1 = murmuration_profile(pool_r1)\n",
    "p_r2, avg_r2, std_r2 = murmuration_profile(pool_r2)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Left panel: point cloud + averages\n",
    "ax = axes[0]\n",
    "colors = ['#2196F3', '#FF9800', '#E91E63']\n",
    "for pool, color in zip([pool_r0, pool_r1, pool_r2], colors):\n",
    "    for data in pool:\n",
    "        ps, vals = ap_normalized(data, PRIMES_OPT)\n",
    "        ax.scatter(ps, vals, alpha=0.04, s=3, color=color)\n",
    "\n",
    "for p_avg, avg, lbl, color in [\n",
    "    (p_r0, avg_r0, 'Rank 0 average', colors[0]),\n",
    "    (p_r1, avg_r1, 'Rank 1 average', colors[1]),\n",
    "    (p_r2, avg_r2, 'Rank 2 average', colors[2])\n",
    "]:\n",
    "    ax.plot(p_avg, avg, color=color, linewidth=2.5, label=lbl)\n",
    "\n",
    "ax.axhline(0, color='black', lw=0.8, ls='--', alpha=0.5)\n",
    "ax.set_xlabel('Prime p')\n",
    "ax.set_ylabel('a_p / sqrt(p)')\n",
    "ax.set_title('Murmurations by Rank\\n31 curves - real LMFDB data')\n",
    "ax.legend(fontsize=9)\n",
    "ax.set_ylim(-2.5, 2.5)\n",
    "\n",
    "# Right panel: averages only zoomed in\n",
    "ax2 = axes[1]\n",
    "for p_avg, avg, std, lbl, color in [\n",
    "    (p_r0, avg_r0, std_r0, 'Rank 0', colors[0]),\n",
    "    (p_r1, avg_r1, std_r1, 'Rank 1', colors[1]),\n",
    "    (p_r2, avg_r2, std_r2, 'Rank 2', colors[2])\n",
    "]:\n",
    "    ax2.plot(p_avg, avg, color=color, linewidth=2.5, label=lbl)\n",
    "    ax2.fill_between(p_avg, avg - std/4, avg + std/4, alpha=0.15, color=color)\n",
    "\n",
    "ax2.axhline(0, color='black', lw=0.8, ls='--', alpha=0.5)\n",
    "ax2.set_xlabel('Prime p')\n",
    "ax2.set_ylabel('Average a_p / sqrt(p)')\n",
    "ax2.set_title('Murmuration waves - averages only\\nOpposite directions confirm rank separation')\n",
    "ax2.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('fig2_murmurations.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Murmurations visible: opposite waves per rank')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Part 4: Rank Classifier via Murmurations\n",
    "\n",
    "We build a classifier that predicts the rank (0, 1 or 2) of an elliptic curve\n",
    "based solely on its murmuration profile, using Mean Squared Error distance\n",
    "to pool averages."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 6: RANK CLASSIFIER\n",
    "\n",
    "def classify_rank(data, avg_r0, avg_r1, avg_r2, p_ref, p_max=PRIMES_OPT):\n",
    "    ps, vals = ap_normalized(data, p_max)\n",
    "    vals_interp = np.interp(p_ref, ps, vals)\n",
    "    d0 = np.mean((vals_interp - avg_r0) ** 2)\n",
    "    d1 = np.mean((vals_interp - avg_r1) ** 2)\n",
    "    d2 = np.mean((vals_interp - avg_r2) ** 2)\n",
    "    distances = [d0, d1, d2]\n",
    "    return np.argmin(distances), distances\n",
    "\n",
    "\n",
    "print('Classifier defined OK')\n",
    "print('Testing on one curve:')\n",
    "pred, dists = classify_rank(pool_r1[0], avg_r0, avg_r1, avg_r2, p_r0)\n",
    "print(f'  {pool_r1[0][\"label\"]} -> Predicted rank: {pred} (true rank: 1)')\n",
    "print(f'  Distances: r0={dists[0]:.3f} r1={dists[1]:.3f} r2={dists[2]:.3f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Part 5: Leave-One-Out Validation (LOO)\n",
    "\n",
    "The most honest validation for small samples: remove each curve from its pool,\n",
    "recompute the average without it, then classify it alone.\n",
    "\n",
    "This eliminates any risk of a curve 'seeing its own exam'."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 7: LEAVE-ONE-OUT VALIDATION\n",
    "\n",
    "def loo_test(pool_r0, pool_r1, pool_r2):\n",
    "    results = []\n",
    "    all_pools = [(pool_r0, 0), (pool_r1, 1), (pool_r2, 2)]\n",
    "\n",
    "    for true_rank, (pool, rank_idx) in enumerate(all_pools):\n",
    "        for i, data in enumerate(pool):\n",
    "            # Recompute averages WITHOUT this curve\n",
    "            pool_without = [d for j, d in enumerate(pool) if j != i]\n",
    "            if len(pool_without) == 0:\n",
    "                continue\n",
    "\n",
    "            _, avg_r0_loo, _ = murmuration_profile(pool_r0 if rank_idx != 0\n",
    "                                                    else pool_without)\n",
    "            _, avg_r1_loo, _ = murmuration_profile(pool_r1 if rank_idx != 1\n",
    "                                                    else pool_without)\n",
    "            _, avg_r2_loo, _ = murmuration_profile(pool_r2 if rank_idx != 2\n",
    "                                                    else pool_without)\n",
    "\n",
    "            pred, dists = classify_rank(\n",
    "                data, avg_r0_loo, avg_r1_loo, avg_r2_loo, p_r0\n",
    "            )\n",
    "\n",
    "            correct = (pred == rank_idx)\n",
    "            margin = sorted(dists)[1] - sorted(dists)[0]\n",
    "            results.append({\n",
    "                'label': data['label'],\n",
    "                'true_rank': rank_idx,\n",
    "                'pred_rank': pred,\n",
    "                'correct': correct,\n",
    "                'margin': margin,\n",
    "                'distances': dists\n",
    "            })\n",
    "\n",
    "    return results\n",
    "\n",
    "\n",
    "print('Running Leave-One-Out validation...')\n",
    "loo_results = loo_test(pool_r0, pool_r1, pool_r2)\n",
    "\n",
    "correct_total = sum(r['correct'] for r in loo_results)\n",
    "total = len(loo_results)\n",
    "\n",
    "print(f'\\nLOO RESULT: {correct_total}/{total} correct ({100*correct_total/total:.1f}%)')\n",
    "print()\n",
    "\n",
    "for rank in [0, 1, 2]:\n",
    "
